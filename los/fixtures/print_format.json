  "html": "<style>\n  body {\n    font-family: Arial;\n    font-size: 12px;\n  }\n  .header {\n    text-align: center;\n    border-bottom: 3px solid #003399;\n    padding-bottom: 10px;\n    margin-bottom: 15px;\n  }\n  .bank-name {\n    color: #003399;\n    font-size: 22px;\n    font-weight: bold;\n  }\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    margin: 10px 0;\n  }\n  td, th {\n    border: 1px solid #ddd;\n    padding: 6px;\n    text-align: left;\n  }\n  th {\n    background: #003399;\n    color: white;\n  }\n</style>\n\n<div class=\"header\">\n  <div class=\"bank-name\">{{ doc.bank }}</div>\n  <div>{{ doc.branch }}</div>\n  <h2>LOAN SANCTION LETTER</h2>\n</div>\n\n<table style=\"border: none;\">\n  <tr>\n    <td style=\"border: none;\">\n      <b>Ref No:</b> {{ doc.name }}\n    </td>\n    <td style=\"border: none; text-align: right;\">\n      <b>Date:</b> {{ doc.sanctioned_on or \"\" }}\n    </td>\n  </tr>\n</table>\n\n<br>\n\n<p>To,</p>\n<p>\n  <b>{{ doc.applicant_name }}</b><br>\n  {{ doc.address }}<br>\n  Mobile: {{ doc.mobile_number }}<br>\n  Email: {{ doc.email }}\n</p>\n\n<br>\n\n<p>\n  <b>Sub: Sanction of {{ doc.loan_product }}\n  — Application No. {{ doc.name }}</b>\n</p>\n\n<p>Dear {{ doc.applicant_name }},</p>\n\n<p>\n  We are pleased to inform you that your loan application has been sanctioned\n  subject to the following terms and conditions:\n</p>\n\n<table>\n  <tr>\n    <th colspan=\"2\" style=\"text-align:center;\">\n      SANCTION DETAILS\n    </th>\n  </tr>\n  <tr>\n    <td><b>Sanctioned Amount</b></td>\n    <td><b>₹{{ doc.sanctioned_amount }}</b></td>\n  </tr>\n  <tr>\n    <td><b>Loan Product</b></td>\n    <td>{{ doc.loan_product }}</td>\n  </tr>\n  <tr>\n    <td><b>Interest Rate</b></td>\n    <td>{{ doc.interest_rate }}% p.a. ({{ doc.interest_type }})</td>\n  </tr>\n  <tr>\n    <td><b>Tenure</b></td>\n    <td>{{ doc.tenure_months }} Months</td>\n  </tr>\n  <tr>\n    <td><b>Monthly EMI</b></td>\n    <td><b>₹{{ doc.emi_amount }}</b></td>\n  </tr>\n  <tr>\n    <td><b>Processing Fee</b></td>\n    <td>₹{{ doc.processing_fee_amount }}</td>\n  </tr>\n  <tr>\n    <td><b>Total Repayment</b></td>\n    <td>₹{{ doc.total_repayment_amount }}</td>\n  </tr>\n  <tr>\n    <td><b>Purpose</b></td>\n    <td>{{ doc.purpose_of_loan }}</td>\n  </tr>\n</table>\n\n<br>\n\n<p><b>Terms and Conditions:</b></p>\n<ol>\n  <li>Loan sanctioned subject to submission of all required documents.</li>\n  <li>EMI payments must be made on time to avoid penalties.</li>\n  <li>Late payment attracts penalty as per bank policy.</li>\n  <li>Bank reserves the right to recall loan in case of default.</li>\n  <li>This sanction letter is valid for 30 days from date of issue.</li>\n</ol>\n\n<br><br>\n\n<table style=\"border: none;\">\n  <tr>\n    <td style=\"border: none; width: 50%;\">\n      ________________________<br>\n      <b>{{ doc.sanctioned_by or \"\" }}</b><br>\n      Sanctioning Authority<br>\n      {{ doc.branch }}\n    </td>\n    <td style=\"border: none; text-align: right;\">\n      Place: {{ doc.branch }}<br>\n      Date: {{ doc.sanctioned_on or \"\" }}\n    </td>\n  </tr>\n</table>\n\n<br><br>\n\n<table style=\"border: none;\">\n  <tr>\n    <td style=\"border: none;\">\n      <b>ACCEPTANCE BY BORROWER:</b><br><br>\n      I accept the above sanction and agree to the terms and conditions.\n      <br><br><br>\n      ________________________<br>\n      {{ doc.applicant_name }}<br>\n      Date: _______________\n    </td>\n  </tr>\n</table>",
