  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Loan Application Form</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    background-color: #f5f5f5;\n    padding: 20px;\n    color: #333;\n  }\n\n  .form-container {\n    width: 95%;\n    margin: auto;\n    background: #fff;\n    padding: 30px;\n    border-radius: 10px;\n    box-shadow: 0 4px 15px rgba(0,0,0,0.1);\n  }\n\n  h1, h2 {\n    text-align: center;\n    color: #003399;\n    margin: 5px 0;\n  }\n\n  h2 {\n    margin-top: 30px;\n    margin-bottom: 15px;\n    font-size: 18px;\n  }\n\n  .section {\n    margin-bottom: 25px;\n  }\n\n  .row {\n    display: flex;\n    flex-wrap: wrap;\n    margin-bottom: 10px;\n  }\n\n  .row div {\n    flex: 1 1 48%;\n    padding: 5px 10px;\n    box-sizing: border-box;\n  }\n\n  .label {\n    font-weight: bold;\n    color: #555;\n  }\n\n  /* Signature Styles */\n  .signature {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 60px;\n  }\n\n  .signature-block {\n    width: 48%;\n    text-align: center;\n  }\n\n  .signature-line {\n    border-top: 1px solid #333;\n    margin-bottom: 5px;\n    height: 0;\n  }\n\n  /* Print-friendly */\n  @media print {\n    body { background: #fff; padding: 0; }\n    .form-container { width: 100%; box-shadow: none; border-radius: 0; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"form-container\">\n    <h1>Indian Bank</h1>\n    <p style=\"text-align:center; color:#555;\">IB-002</p>\n    <h2>Loan Application Form</h2>\n    <p style=\"text-align:center;\">\n      Application No: <strong>{{ doc.name }}</strong> |\n      Date: <strong>{{ doc.application_date or nowdate() }}</strong>\n    </p>\n\n    <!-- Applicant Details -->\n    <div class=\"section\">\n      <h2>Applicant Details</h2>\n      <div class=\"row\">\n        <div><span class=\"label\">Applicant Name:</span> {{ doc.applicant_name or 'N/A' }}</div>\n        <div><span class=\"label\">Date of Birth:</span> {{ doc.date_of_birth or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Age:</span> {{ doc.age or 'N/A' }}</div>\n        <div><span class=\"label\">Gender:</span> {{ doc.gender or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Mobile:</span> {{ doc.mobile_no or 'N/A' }}</div>\n        <div><span class=\"label\">Email:</span> {{ doc.email or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">PAN:</span> {{ doc.pan or 'N/A' }}</div>\n        <div><span class=\"label\">Aadhar:</span> {{ doc.aadhar or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div style=\"flex:1;\"><span class=\"label\">Address:</span> {{ doc.address or 'N/A' }}</div>\n      </div>\n    </div>\n\n    <!-- Employment & Financial Details -->\n    <div class=\"section\">\n      <h2>Employment & Financial Details</h2>\n      <div class=\"row\">\n        <div><span class=\"label\">Employment Type:</span> {{ doc.employment_type or 'N/A' }}</div>\n        <div><span class=\"label\">Employer:</span> {{ doc.employer or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Monthly Income:</span> ₹{{ doc.monthly_income or 0 }}</div>\n        <div><span class=\"label\">Other Income:</span> ₹{{ doc.other_income or 0 }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Total Income:</span> ₹{{ doc.total_income or 0 }}</div>\n        <div><span class=\"label\">Existing EMI:</span> ₹{{ doc.existing_emi or 0 }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Net Eligible Income:</span> ₹{{ doc.net_eligible_income or 0 }}</div>\n        <div><span class=\"label\">CIBIL Score:</span> {{ doc.cibil_score or 'N/A' }}</div>\n      </div>\n    </div>\n\n    <!-- Loan Details -->\n    <div class=\"section\">\n      <h2>Loan Details</h2>\n      <div class=\"row\">\n        <div><span class=\"label\">Loan Product:</span> {{ doc.loan_product or 'N/A' }}</div>\n        <div><span class=\"label\">Loan Amount:</span> ₹{{ doc.loan_amount or 0 }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Tenure:</span> {{ doc.tenure or 'N/A' }}</div>\n        <div><span class=\"label\">Interest Rate:</span> {{ doc.interest_rate or 'N/A' }}%</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">EMI:</span> ₹{{ doc.emi or 0 }}</div>\n        <div><span class=\"label\">Processing Fee:</span> ₹{{ doc.processing_fee or 0 }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Total Repayment:</span> ₹{{ doc.total_repayment or 0 }}</div>\n        <div><span class=\"label\">Purpose:</span> {{ doc.loan_purpose or 'N/A' }}</div>\n      </div>\n    </div>\n\n    <!-- Nominee Details -->\n    <div class=\"section\">\n      <h2>Nominee Details</h2>\n      <div class=\"row\">\n        <div><span class=\"label\">Name:</span> {{ doc.nominee_name or 'N/A' }}</div>\n        <div><span class=\"label\">Relationship:</span> {{ doc.nominee_relationship or 'N/A' }}</div>\n      </div>\n      <div class=\"row\">\n        <div><span class=\"label\">Share %:</span> {{ doc.nominee_share or 0 }}%</div>\n        <div><span class=\"label\">Contact:</span> {{ doc.nominee_contact or 'N/A' }}</div>\n      </div>\n    </div>\n\n    <!-- Signatures -->\n    <div class=\"signature\">\n      <div class=\"signature-block\">\n        <div class=\"signature-line\"></div>\n        <p>Applicant Signature</p>\n        <p>{{ doc.applicant_name or 'N/A' }}</p>\n      </div>\n\n      <div class=\"signature-block\">\n        <div class=\"signature-line\"></div>\n        <p>Bank Official</p>\n        <p>Date: {{ doc.application_date or nowdate() }}</p>\n      </div>\n    </div>\n\n  </div>\n</body>\n</html>",
